"""
DB_USER=your_db_user
DB_PASSWORD=your_password
DB_HOST=your_localhost
DB_PORT=your_port
DB_NAME=your_db_name
"""
DB_USER=postgres                # PostgreSQL kullanıcı adın, genelde 'postgres' olur.
DB_PASSWORD=12345               # PostgreSQL şifren (Eğer boşsa boş bırak ama genelde şifre belirlenmiştir.)
DB_HOST=localhost               # Eğer yerel sunucuysa 'localhost' veya '127.0.0.1'
DB_PORT=5432                    # PostgreSQL'in dinlediği port (Senin durumda 5432, bu doğru)
DB_NAME=gyk1             # Bağlanmak istediğin veritabanının adı
